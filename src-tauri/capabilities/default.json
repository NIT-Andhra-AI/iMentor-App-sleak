{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Student AI — grants IPC, dialog and fs access to the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-copy-file",
    "fs:allow-rename",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-stat",
    "fs:allow-open",
    "fs:scope-appdata-recursive",
    "fs:scope-applocaldata-recursive"
  ]
}
