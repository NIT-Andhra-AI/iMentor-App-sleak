# ─────────────────────────────────────────────────────────────────────────────
# Student AI — Caddyfile
#
# Fill in YOUR values:
#   YOUR_PUBLIC_IP  — the NAT'd public IP your IT admin gave you
#   YOUR_LAN_IP     — the machine's private IP on the campus LAN
#                     (run `ip addr` on Linux or `ipconfig` on Windows)
#
# Listing BOTH addresses in one site block means Caddy answers requests
# arriving on either interface, solving the NAT-hairpin problem:
#   • Off-campus students  →  hit YOUR_PUBLIC_IP  (works fine)
#   • On-campus students   →  hit YOUR_LAN_IP     (bypasses broken NAT)
#
# TLS:
#   • Bare IPs cannot get Let's Encrypt certs.
#   • `tls internal` makes Caddy its own local CA — add the root cert to
#     student machines once (via GPO or a setup script) for a green padlock.
#   • Alternatively remove `tls internal` and use plain HTTP on both IPs
#     (acceptable on a trusted LAN, but HTTPS is recommended for the telemetry
#     data to be encrypted in transit).
#
# Start:  caddy run --config Caddyfile
# Reload: caddy reload --config Caddyfile
# ─────────────────────────────────────────────────────────────────────────────

YOUR_PUBLIC_IP, YOUR_LAN_IP {

    tls internal   # self-signed via Caddy local CA — works for both IPs

    # ── API: telemetry + course catalog (student app) ─────────────────────
    handle /v1/* {
        reverse_proxy localhost:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # ── Admin API (protected by X-Admin-Key header) ───────────────────────
    handle /admin/api/* {
        reverse_proxy localhost:8000
    }

    # ── Admin dashboard static files ──────────────────────────────────────
    handle /dashboard* {
        reverse_proxy localhost:8000
    }

    # ── Health check (used by the app's EndpointResolver probe) ──────────
    handle /health {
        reverse_proxy localhost:8000
    }

    # ── Security headers ──────────────────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        -Server
    }

    # ── Logging ───────────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/studentai.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}

